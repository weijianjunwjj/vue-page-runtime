{
  "name": "vue-page-runtime",
  "version": "0.1.1",
  "description": "vue-page-store 的任务编排插件 —— 在 definePageStore 中声明 tasks，获得自动运行 / 依赖顺序 / loading / abort",
  "author": "weijianjun",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weijianjun/vue-page-runtime.git"
  },
  "bugs": {
    "url": "https://github.com/weijianjun/vue-page-runtime/issues"
  },
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "unpkg": "dist/index.umd.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rollup -c rollup.config.mjs && node scripts/copy-types.js",
    "prepublishOnly": "npm run build",
    "release": "bash scripts/release.sh"
  },
  "peerDependencies": {
    "vue": "^2.6.0",
    "vue-page-store": "^0.5.0"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "rollup": "^3.29.4"
  },
  "keywords": [
    "vue",
    "vue2",
    "page-store",
    "page-runtime",
    "task",
    "async",
    "loading",
    "plugin"
  ]
}
